# Server Configuration
# The port number on which the Express server will listen.
PORT=
# The MongoDB connection string, including credentials and database name.
MONGO_URI=

# Single Sign-On (SSO) Configuration
# The base URL of the OpenID Connect (OIDC) issuer.
SSO_ISSUER_URL=
# The client ID provided by the SSO provider for this application.
SSO_CLIENT_ID=
# The client secret provided by the SSO provider. KEEP THIS SECURE.
SSO_CLIENT_SECRET=
# The callback URL where the SSO provider redirects after successful authentication.
SSO_REDIRECT_URI=

# Identification and Authorization Settings
# Defines which claim from the SSO provider to use as the primary user identifier.
# Use 'email' for standard OIDC providers or 'username' for organizational Active Directory.
SSO_IDENTIFIER_FIELD=

# Super Admin Identity
# These must match the exact attributes of the administrative user in the identity provider.
# Used to bootstrap initial administrative access.
SUPER_ADMIN_ID=
SUPER_ADMIN_USERNAME=
SUPER_ADMIN_EMAIL=

# Super Admin Group Assignment
# The name of the group that grants full system administrative privileges.
# This MUST match the group name defined in the client-side configuration.
SUPER_ADMIN_GROUP_NAME=
